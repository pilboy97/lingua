func main() {
    var arr = []num{}
    var N = 1000
    var i num
    var j num

    for(i = 0;i < N;i = i + 1) {
        append(arr, N - i)
    }
    for(i = 0;i < N;i = i + 1) {
        for(j = 0;j < N - 1;j = j + 1) {
            if(arr[j] > arr[j + 1]) {
                var tmp = arr[j]
                arr[j] = arr[j + 1]
                arr[j + 1] = tmp
            }
        }
    }
    for(i = 0;i < N;i = i + 1) {
        print("" + arr[i] + "\n")
    }
}