package main

func main() {
    var list = []num {1, 2, 3}
    printf("%v\n", list)       // [1, 2, 3]
    printf("%d\n", list[1])    // 2
    printf("%d\n", list.len()) // 3
    printf("%d\n", list.cap()) // 3

    list.append(4)
    printf("%v", list)         // [1,2,3,4] 
    printf("%d\n", list[1])    // 2
    printf("%d\n", list.len()) // 4
    printf("%d\n", list.cap()) // 6

    delete list
}