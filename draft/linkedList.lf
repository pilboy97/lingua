class Node {
    value num
    next Node
}

func main() {
    var x = Node {
        value: 1,
    }
    var y = Node {
        value: 2,
    }
    var z = Node {
        value: 3,
    }

    x.next = y
    y.next = z

    var it = x

    for(it is not null) {
        print("" + it.value + "\n")
        it = it.next
    }
}