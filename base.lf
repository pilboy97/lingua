interface Error {
    error() -> []byte
}
class ErrDivideByZero {
    ---
    error() -> []byte {
        return "divided by zero"
    }
}
class ErrNullPointer {
    ---
    error() -> []byte {
        return "try to access null pointer"
    }
}
func makeErrDivideByZero() -> ErrDivideByZero {
    return ErrDivideByZero{}
}
func makeErrNullPointer() -> ErrNullPointer {
    return ErrNullPointer{}
}