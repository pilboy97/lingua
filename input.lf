class Human {
    ---
    walk() {
        print("성큼성큼")
    }
}
class Duck {
    ---
    walk() {
        print("뒤뚱뒤뚱")
    }
}
class RobotDuck {
    ---
    walk() {
        print("beep beep")
    }
}
interface Walkable {
    walk()
}
func f() -> Walkable {
    return RobotDuck{}
}
func main() {
    var robot = f() as RobotDuck
    robot.walk()
}