func main() {
    var divider = []num{}
    var N = 12
    var i num
    for (i = 1;i <= N;i = i + 1) {
        if(N % i == 0) {
            append(divider, i)
        }
    }

    for(i = 0;i < len(divider);i = i + 1) {
        print("" + divider[i] + "\n")
    }
    shrink(divider)
    print("" + len(divider) + " " + cap(divider) + "\n")
}